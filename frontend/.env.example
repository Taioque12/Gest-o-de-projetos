# Gemini (análise de IA do cronograma)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash

# Backend de leitura .mpp/.mpx (opcional — ver backend-mpp/README.md)
# Sem essa var, o import continua funcionando normalmente via XML.
VITE_MPP_API_URL=

# Mercado Pago (MP_ACCESS_TOKEN) e SUPABASE_SERVICE_ROLE_KEY ficam como
# secrets das Edge Functions (mp-criar-assinatura, mp-webhook,
# admin-create-user) no painel do Supabase — não entram no .env do frontend.
